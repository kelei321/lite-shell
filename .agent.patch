+fn ensure_file_target(
+    is_directory: bool,
+    code: &'static str,
+    message: &'static str,
+) -> Result<(), CommandError> {
+    if is_directory {
+        Err(CommandError::new(code, message))
+    } else {
+        Ok(())
+    }
+}
+
+fn ensure_directory_target(
+    is_directory: bool,
+    code: &'static str,
+    message: &'static str,
+) -> Result<(), CommandError> {
+    if is_directory {
+        Ok(())
+    } else {
+        Err(CommandError::new(code, message))
+    }
+}
