{
  "name": "lite-shell",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "format": "npm run format:rust",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
    "format:check": "npm run format:check:rust",
    "format:check:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check",
    "lint": "npm run lint:rust",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D clippy::correctness -D clippy::suspicious",
    "test": "npm run test:frontend && npm run test:rust",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml --all-targets --all-features",
    "check": "npm run format:check && npm run lint && npm run typecheck",
    "validate": "npm run check && npm run test && npm run build",
    "tauri": "tauri",
    "desktop": "tauri dev",
    "desktop:build": "tauri build",
    "test:frontend": "node --experimental-strip-types --test src/sftp/*.test.mjs"
  },
  "dependencies": {
    "@tabler/icons-vue": "^3.34.1",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "vite": "6.4.2",
    "vue": "^3.5.17"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.0",
    "typescript": "^5.8.3",
    "vue-tsc": "^2.2.10"
  }
}
